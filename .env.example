# Copy this file to ".env" for local dev. The real .env is gitignored.
# These same values should be set in the GitHub Actions workflow (or as repo
# variables) for the production build.

# Your Amazon Associates tracking ID (e.g. red4golf-20). Appended to book links.
# Overrides the value in src/data/site.json.
PUBLIC_AMAZON_TAG=

# GoatCounter site code. If your dashboard is https://pnwhistory.goatcounter.com
# then this value is "pnwhistory". Leave blank to disable analytics locally.
PUBLIC_GOATCOUNTER_CODE=

# Google Search Console verification token — the "content" value from the
# "HTML tag" verification method. Emits <meta name="google-site-verification">.
# See /admin/seo for setup steps. Not secret.
PUBLIC_GOOGLE_SITE_VERIFICATION=

# Repo "owner/name" for the /admin build-health panel (reads GitHub Actions
# runs via the public API — no token). Defaults to red4golf/PNWHistoricalExplorer.
PUBLIC_GITHUB_REPO=
