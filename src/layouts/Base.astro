---
import '../styles/global.css';
import { base, href } from '../lib/url';
import { GOATCOUNTER_CODE } from '../config';

// Only emit analytics on the real production build (not dev/preview), and only
// when a GoatCounter code is configured. import.meta.env.PROD is true in builds.
const analyticsEnabled = import.meta.env.PROD && !!GOATCOUNTER_CODE;
const goatCounterEndpoint = `https://${GOATCOUNTER_CODE}.goatcounter.com/count`;

interface Props {
  title: string;
  description?: string;
  ogImage?: string | null;
  ogType?: string;
}

const {
  title,
  description = 'Explore 90+ historical sites across the Pacific Northwest — with in-depth stories, audio narrations, and curated reading for every location.',
  ogImage = null,
  ogType = 'website',
} = Astro.props;

const canonical = new URL(Astro.url.pathname, Astro.site);
const ogImageUrl = ogImage
  ? new URL(href(ogImage), Astro.site).href
  : new URL(href('/icons/og-default.png'), Astro.site).href;

// Path without the base prefix, for nav highlighting
const path = Astro.url.pathname.startsWith(base)
  ? Astro.url.pathname.slice(base.length) || '/'
  : Astro.url.pathname;
const current = (h: string) => (h === '/' ? (path === '/' ? 'page' : undefined) : path.startsWith(h) ? 'page' : undefined);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />

    <link rel="icon" href={href('/favicon.ico')} sizes="32x32" />
    <link rel="icon" href={href('/icons/icon.svg')} type="image/svg+xml" />
    <link rel="apple-touch-icon" href={href('/icons/apple-touch-icon.png')} />
    <link rel="manifest" href={href('/manifest.webmanifest')} />
    <meta name="theme-color" content="#1f3d2b" />

    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImageUrl} />
    <meta name="twitter:card" content="summary_large_image" />

    <link rel="sitemap" href={href('/sitemap-index.xml')} />
    <slot name="head" />

    {analyticsEnabled && (
      <script
        is:inline
        data-goatcounter={goatCounterEndpoint}
        async
        src="//gc.zgo.at/count.js"></script>
    )}
  </head>
  <body>
    <header class="site-header">
      <div class="container">
        <a href={href('/')} class="brand">
          <svg width="26" height="26" viewBox="0 0 24 24" fill="none" aria-hidden="true">
            <path d="M12 2 L4 20 H9 L12 13 L15 20 H20 Z" fill="#c9a227" />
            <path d="M12 7 L7.5 20 H16.5 Z" fill="#ece1cb" opacity="0.9" />
          </svg>
          PNW Historical Explorer
        </a>
        <nav class="main-nav" aria-label="Primary">
          <a href={href('/')} aria-current={current('/')}>Home</a>
          <a href={href('/map')} aria-current={current('/map')}>Map</a>
          <a href={href('/categories')} aria-current={current('/categories')}>Categories</a>
          <a href={href('/about')} aria-current={current('/about')}>About</a>
        </nav>
      </div>
    </header>

    <main>
      <slot />
    </main>

    <footer class="site-footer">
      <div class="container">
        <div>
          <strong>PNW Historical Explorer</strong><br />
          Stories, audio tours, and reading guides for the Pacific Northwest’s historic places.
        </div>
        <div>
          <a href={href('/map')}>Explore the map</a> ·
          <a href={href('/categories')}>Browse categories</a> ·
          <a href={href('/about')}>About</a>
        </div>
      </div>
    </footer>

    <nav class="bottom-nav" aria-label="Mobile">
      <a href={href('/')} aria-current={current('/')}><span class="ico">🏠</span>Home</a>
      <a href={href('/map')} aria-current={current('/map')}><span class="ico">🗺️</span>Map</a>
      <a href={href('/categories')} aria-current={current('/categories')}><span class="ico">🏛️</span>Browse</a>
      <a href={href('/about')} aria-current={current('/about')}><span class="ico">ℹ️</span>About</a>
    </nav>

    <script define:vars={{ swPath: href('/sw.js'), swScope: base + '/' }}>
      if ('serviceWorker' in navigator) {
        window.addEventListener('load', () => {
          navigator.serviceWorker.register(swPath, { scope: swScope }).catch(() => {});
        });
      }
    </script>
  </body>
</html>
