---
import Base from '../layouts/Base.astro';
import { href } from '../lib/url';

// Pagefind UI assets are generated into dist/pagefind/ at build time.
// We reference them via the base-aware href() helper so the paths work
// on both GitHub Pages (/PNWHistoricalExplorer) and any custom domain.
const pagefindUiCss = href('/pagefind/pagefind-ui.css');
const pagefindUiJs  = href('/pagefind/pagefind-ui.js');
const bundlePath    = href('/pagefind/');
---

<Base
  title="Search — PNW Historical Explorer"
  description="Search all historical sites across the Pacific Northwest — forts, lighthouses, ghost towns, and more."
>
  <Fragment slot="head">
    <!--
      Pagefind CSS only exists after `npm run build`. In dev the link is a
      404 (harmless). The JS is loaded dynamically below for the same reason.
    -->
    <link rel="stylesheet" href={pagefindUiCss} />
  </Fragment>

  <!-- Search hero ------------------------------------------------------- -->
  <section class="search-hero">
    <div class="container">
      <h1>Search</h1>
      <p>Find historical sites across the Pacific Northwest.</p>
    </div>
  </section>

  <!-- Search UI ---------------------------------------------------------- -->
  <section class="section">
    <div class="container">
      <div id="pagefind-search"></div>
      <noscript>
        <p class="search-noscript">
          Search requires JavaScript. Browse by
          <a href={href('/categories')}>category</a> or explore the
          <a href={href('/map')}>map</a>.
        </p>
      </noscript>
    </div>
  </section>
</Base>

<!--
  Load pagefind-ui.js dynamically so a missing index (dev mode) shows a
  friendly message instead of a hard error, and so we can pass bundlePath
  computed from Astro's base URL at build time.
-->
<script is:inline define:vars={{ pagefindUiJs, bundlePath }}>
  (function () {
    var container = document.getElementById('pagefind-search');

    function initUI() {
      // PagefindUI is registered as a global by pagefind-ui.js
      new PagefindUI({
        element: '#pagefind-search',
        bundlePath: bundlePath,
        showImages: false,
        excerptLength: 20,
        resetStyles: false,
      });
    }

    var script = document.createElement('script');
    script.src = pagefindUiJs;
    script.onload = initUI;
    script.onerror = function () {
      if (container) {
        container.innerHTML =
          '<p class="search-unavailable">' +
          'Search index not found. Run <code>npm run build</code> to generate it, ' +
          'then use <code>npm run preview</code> to test search locally.' +
          '</p>';
      }
    };
    document.head.appendChild(script);
  })();
</script>

<style>
  /* ---- hero ---- */
  .search-hero {
    background: var(--forest);
    color: var(--cream);
    padding: 2.5rem 0 2rem;
  }

  .search-hero h1 {
    color: #fff;
    margin-bottom: 0.25rem;
    font-size: clamp(1.7rem, 4vw, 2.4rem);
  }

  .search-hero p {
    color: var(--parchment);
    margin: 0;
    font-size: 1.05rem;
  }

  /* ---- Pagefind UI theme overrides ---- */
  /*
   * Pagefind Default UI exposes CSS custom properties for theming.
   * We map them to the site's own design tokens here.
   * See: https://pagefind.app/docs/ui/#customising-the-styles
   */
  #pagefind-search {
    --pagefind-ui-scale: 1;
    --pagefind-ui-primary: var(--forest);
    --pagefind-ui-text: var(--ink);
    --pagefind-ui-background: #fff;
    --pagefind-ui-border: var(--sand);
    --pagefind-ui-tag: var(--parchment);
    --pagefind-ui-border-width: 2px;
    --pagefind-ui-border-radius: 8px;
    --pagefind-ui-image-border-radius: 6px;
    --pagefind-ui-font: var(--font-sans);
    padding-top: 0.5rem;
  }

  /* Input focus ring uses accent color */
  #pagefind-search :global(.pagefind-ui__search-input:focus) {
    outline-color: var(--forest);
  }

  /* Result links */
  #pagefind-search :global(.pagefind-ui__result-link) {
    color: var(--rust);
    font-family: var(--font-serif);
    font-weight: 700;
  }
  #pagefind-search :global(.pagefind-ui__result-link:hover) {
    color: var(--rust-dark);
  }

  /* Tag badges */
  #pagefind-search :global(.pagefind-ui__result-tag) {
    background: var(--parchment);
    color: var(--pine);
    border-radius: 999px;
    font-size: 0.78rem;
    padding: 0.1rem 0.55rem;
  }

  /* "Load more" button */
  #pagefind-search :global(.pagefind-ui__button) {
    background: var(--rust);
    color: #fff;
    border-radius: 999px;
    border: none;
    font-weight: 600;
    padding: 0.6rem 1.4rem;
    cursor: pointer;
    font-size: 0.95rem;
  }
  #pagefind-search :global(.pagefind-ui__button:hover) {
    background: var(--rust-dark);
  }

  /* Message when no results / dev-mode error */
  .search-unavailable,
  .search-noscript {
    color: var(--ink-soft);
    font-style: italic;
    padding: 1rem 0;
    font-size: 0.95rem;
  }

  .search-unavailable code {
    background: var(--parchment);
    border-radius: 4px;
    padding: 0.15em 0.4em;
    font-style: normal;
    font-size: 0.9em;
  }
</style>
