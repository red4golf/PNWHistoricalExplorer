---
import Base from '../layouts/Base.astro';
import { href } from '../lib/url';
---

<Base title="Offline — PNW Historical Explorer" description="You appear to be offline.">
  <section class="section">
    <div class="container" style="max-width:42rem; text-align:center; padding:3rem 0;">
      <div style="font-size:3rem;">🌲</div>
      <h1>You're off the grid</h1>
      <p style="color:var(--ink-soft);">
        This page isn't saved for offline use yet. Pages you've visited before — and any audio
        narrations you've played — are still available.
      </p>
      <p><a class="btn" href={href('/')}>Go to saved home page</a></p>
    </div>
  </section>
</Base>
