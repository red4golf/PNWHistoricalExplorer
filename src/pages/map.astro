---
import Base from '../layouts/Base.astro';
import { CATEGORIES } from '../lib/categories';
import { href } from '../lib/url';
import { publishedLocations } from '../lib/publish';

const locations = await publishedLocations();
const counts = Object.fromEntries(
  CATEGORIES.map((c) => [c.slug, locations.filter((l) => l.data.category === c.name).length])
);
---

<Base
  title="Explorer Map — PNW Historical Explorer"
  description={`Interactive map of ${locations.length} Pacific Northwest historical sites, filterable by category.`}
>
  <section class="section" style="padding-top:1.5rem;">
    <div class="container">
      <h1 style="font-size:1.6rem;">Explorer map</h1>
      <details class="filter-disclosure">
        <summary class="filter-summary">
          <span class="filter-summary-label">Filter by category: <strong id="filter-current">All</strong></span>
          <span class="chev" aria-hidden="true">▸</span>
        </summary>
        <div class="filter-pills" id="filters" role="group" aria-label="Filter by category">
          <button class="pill active" data-cat="all" data-label="All" aria-pressed="true">All ({locations.length})</button>
          {
            CATEGORIES.map((c) => (
              <button class="pill" data-cat={c.slug} data-label={c.name} aria-pressed="false">
                {c.icon} {c.name} ({counts[c.slug]})
              </button>
            ))
          }
        </div>
      </details>
      <div class="map-tools">
        <button id="locate" class="locate-btn" type="button">📍 Find sites near me</button>
        <span id="locate-status" class="locate-status" role="status" aria-live="polite"></span>
      </div>
      <div class="map-wrap">
        <div id="map" data-locations-url={href('/locations.json')}></div>
      </div>
      <div id="nearby" class="nearby" hidden>
        <h2 class="nearby-title">Nearest sites to you</h2>
        <ol id="nearby-list" class="nearby-list"></ol>
      </div>
    </div>
  </section>

  <script>
    import L from 'leaflet';
    import 'leaflet.markercluster';
    import 'leaflet/dist/leaflet.css';
    import 'leaflet.markercluster/dist/MarkerCluster.css';
    import 'leaflet.markercluster/dist/MarkerCluster.Default.css';

    import markerIcon2x from 'leaflet/dist/images/marker-icon-2x.png';
    import markerIcon from 'leaflet/dist/images/marker-icon.png';
    import markerShadow from 'leaflet/dist/images/marker-shadow.png';

    // Fix Leaflet's default icon paths under bundlers
    L.Icon.Default.mergeOptions({
      iconRetinaUrl: markerIcon2x.src,
      iconUrl: markerIcon.src,
      shadowUrl: markerShadow.src,
    });

    const BASE = import.meta.env.BASE_URL.replace(/\/$/, '');
    const el = document.getElementById('map')!;
    const map = L.map(el, { scrollWheelZoom: true }).setView([46.8, -121.5], 6);

    L.tileLayer('https://tile.openstreetmap.org/{z}/{x}/{y}.png', {
      maxZoom: 19,
      attribution: '&copy; <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a> contributors',
    }).addTo(map);

    const cluster = (L as any).markerClusterGroup({ showCoverageOnHover: false, maxClusterRadius: 46 });
    map.addLayer(cluster);

    type Loc = {
      slug: string; title: string; category: string; categorySlug: string;
      period: string | null; lat: number; lng: number; description: string;
      heroImage: string | null; hasAudio: boolean;
    };

    let all: Loc[] = [];
    let markers: Record<string, L.Marker> = {};

    function popupHtml(l: Loc) {
      const img = l.heroImage
        ? `<img src="${l.heroImage.replace(/\.(jpe?g|png)$/i, '-card.webp')}" onerror="this.onerror=null;this.src='${l.heroImage}'" alt="" style="width:100%;height:110px;object-fit:cover;border-radius:6px;margin-bottom:6px;">`
        : '';
      return `${img}<strong style="font-size:1rem;">${l.title}</strong><br>
        <span style="color:#5a5246;font-size:0.8rem;">${l.category}${l.period ? ' · ' + l.period : ''}${l.hasAudio ? ' · 🎧' : ''}</span>
        <p style="margin:6px 0;font-size:0.85rem;">${l.description}…</p>
        <a href="${BASE}/locations/${l.slug}" style="font-weight:600;">Read the full story →</a>`;
    }

    function renderMarkers(catSlug: string) {
      cluster.clearLayers();
      markers = {};
      const subset = catSlug === 'all' ? all : all.filter((l) => l.categorySlug === catSlug);
      for (const l of subset) {
        const m = L.marker([l.lat, l.lng]).bindPopup(popupHtml(l), { maxWidth: 280 });
        markers[l.slug] = m;
        cluster.addLayer(m);
      }
      if (subset.length) {
        map.fitBounds(cluster.getBounds().pad(0.15));
      }
    }

    fetch(el.dataset.locationsUrl!)
      .then((r) => r.json())
      .then((data: Loc[]) => {
        all = data;
        renderMarkers('all');

        // Deep link: /map#slug zooms to that location
        const target = location.hash.slice(1);
        if (target && markers[target]) {
          const m = markers[target];
          map.setView(m.getLatLng(), 13);
          setTimeout(() => m.openPopup(), 400);
        }
      });

    document.getElementById('filters')!.addEventListener('click', (e) => {
      const btn = (e.target as HTMLElement).closest('button.pill') as HTMLButtonElement | null;
      if (!btn) return;
      document.querySelectorAll('#filters .pill').forEach((p) => {
        p.classList.toggle('active', p === btn);
        p.setAttribute('aria-pressed', String(p === btn));
      });
      const cur = document.getElementById('filter-current');
      if (cur) cur.textContent = btn.dataset.label!;
      renderMarkers(btn.dataset.cat!);
    });

    // ---- GPS: locate me + nearest sites ----------------------------------
    const locateBtn = document.getElementById('locate') as HTMLButtonElement;
    const locateStatus = document.getElementById('locate-status')!;
    const nearbyPanel = document.getElementById('nearby')!;
    const nearbyList = document.getElementById('nearby-list')!;
    let userLayer: L.LayerGroup | null = null;

    function distMiles(aLat: number, aLng: number, bLat: number, bLng: number) {
      const R = 3958.8;
      const toRad = (d: number) => (d * Math.PI) / 180;
      const dLat = toRad(bLat - aLat);
      const dLng = toRad(bLng - aLng);
      const s =
        Math.sin(dLat / 2) ** 2 +
        Math.cos(toRad(aLat)) * Math.cos(toRad(bLat)) * Math.sin(dLng / 2) ** 2;
      return 2 * R * Math.asin(Math.sqrt(s));
    }

    locateBtn?.addEventListener('click', () => {
      if (!('geolocation' in navigator)) {
        locateStatus.textContent = 'Geolocation isn’t supported on this device.';
        return;
      }
      locateBtn.disabled = true;
      locateStatus.textContent = 'Locating…';
      (window as any).pnwTrack?.('find-near-me');
      navigator.geolocation.getCurrentPosition(onPos, onErr, {
        enableHighAccuracy: true,
        timeout: 10000,
        maximumAge: 30000,
      });
    });

    function onPos(pos: GeolocationPosition) {
      locateBtn.disabled = false;
      const { latitude: lat, longitude: lng, accuracy } = pos.coords;

      if (userLayer) map.removeLayer(userLayer);
      userLayer = L.layerGroup([
        L.circle([lat, lng], { radius: accuracy, color: '#2b6cff', weight: 1, fillColor: '#2b6cff', fillOpacity: 0.12 }),
        L.circleMarker([lat, lng], { radius: 7, color: '#fff', weight: 2, fillColor: '#2b6cff', fillOpacity: 1 }).bindPopup('You are here'),
      ]).addTo(map);

      const ranked = all
        .map((l) => ({ l, d: distMiles(lat, lng, l.lat, l.lng) }))
        .sort((a, b) => a.d - b.d)
        .slice(0, 8);

      nearbyList.innerHTML = ranked
        .map(
          ({ l, d }) =>
            `<li><a href="#" data-slug="${l.slug}" data-lat="${l.lat}" data-lng="${l.lng}"><span class="n-title">${l.title}</span><span class="n-dist">${d.toFixed(1)} mi</span></a><span class="n-cat">${l.category}</span></li>`
        )
        .join('');
      nearbyPanel.hidden = false;
      locateStatus.textContent = `Found you · accuracy ±${Math.round(accuracy)} m`;

      const bounds = L.latLngBounds([[lat, lng]]);
      ranked.slice(0, 3).forEach(({ l }) => bounds.extend([l.lat, l.lng]));
      map.fitBounds(bounds.pad(0.3));
    }

    function onErr(err: GeolocationPositionError) {
      locateBtn.disabled = false;
      locateStatus.textContent =
        err.code === 1 ? 'Location permission denied.' : 'Couldn’t get your location.';
    }

    nearbyList.addEventListener('click', (e) => {
      const a = (e.target as HTMLElement).closest('a[data-slug]') as HTMLElement | null;
      if (!a) return;
      e.preventDefault();
      const slug = a.dataset.slug!;
      const lat = parseFloat(a.dataset.lat!);
      const lng = parseFloat(a.dataset.lng!);

      // Make sure the marker exists (reset to "All" if a filter is hiding it).
      if (!markers[slug]) {
        document.querySelectorAll('#filters .pill').forEach((p) => {
          const isAll = (p as HTMLElement).dataset.cat === 'all';
          p.classList.toggle('active', isAll);
          p.setAttribute('aria-pressed', String(isAll));
        });
        renderMarkers('all');
      }
      map.setView([lat, lng], 13);
      const m = markers[slug];
      if (m) setTimeout(() => m.openPopup(), 300);
    });
  </script>

  <style>
    .filter-disclosure { border: 1px solid #e1e7e2; border-radius: 10px; background: #fff; margin: .5rem 0 0; }
    .filter-summary { cursor: pointer; list-style: none; display: flex; align-items: center; justify-content: space-between; gap: .5rem; padding: .6rem .9rem; font-size: .95rem; }
    .filter-summary::-webkit-details-marker { display: none; }
    .filter-summary .chev { transition: transform .15s ease; color: #5a6b5f; }
    .filter-disclosure[open] .filter-summary .chev { transform: rotate(90deg); }
    .filter-disclosure .filter-pills { padding: 0 .9rem .8rem; }
    .map-tools { display: flex; align-items: center; gap: .75rem; margin: .75rem 0; flex-wrap: wrap; }
    .locate-btn { background: #1f3d2b; color: #fff; border: 0; border-radius: 999px; padding: .55rem 1rem; font-weight: 600; cursor: pointer; }
    .locate-btn:hover { background: #2a5139; }
    .locate-btn:disabled { opacity: .6; cursor: default; }
    .locate-status { font-size: .85rem; color: #5a6b5f; }
    .nearby { margin: 1.25rem 0 0; }
    .nearby-title { font-size: 1.1rem; margin: 0 0 .5rem; }
    .nearby-list { list-style: none; margin: 0; padding: 0; display: grid; grid-template-columns: repeat(auto-fill, minmax(240px, 1fr)); gap: .5rem; }
    .nearby-list li { background: #fff; border: 1px solid #e1e7e2; border-radius: 10px; padding: .6rem .8rem; }
    .nearby-list a { display: flex; justify-content: space-between; gap: .5rem; align-items: baseline; text-decoration: none; color: inherit; font-weight: 600; }
    .nearby-list a:hover .n-title { text-decoration: underline; }
    .n-dist { color: #1f3d2b; font-variant-numeric: tabular-nums; white-space: nowrap; }
    .n-cat { display: block; font-size: .78rem; color: #5a6b5f; margin-top: .15rem; }
  </style>
</Base>
